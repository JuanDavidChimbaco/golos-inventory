# Golos Inventory - Environment Variables
# Copy this file to .env and modify as needed

# Django Configuration
# Si es para producción 
# DJANGO_SETTINGS_MODULE=config.settings_production 
SECRET_KEY=django-insecure-tukey
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,*.tudominio.com

# Database (SQLite for local development)
DATABASE_URL=sqlite:///db.sqlite3

# Database (PostgreSQL for production)
DB_NAME=nombre_base_datos
DB_USER=usuario
DB_PASSWORD=contraseña
DB_HOST=localhost
DB_PORT=5432

# CORS Settings (for local frontend development)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080,http://localhost:8000,http://127.0.0.1:8000,https://tudominio.com

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=tu-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=tu-email@gmail.com

# JWT Configuration
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440  # 7 days in minutes

# Backblaze Configuration
BACKBLAZE_KEY_ID=tu-key-id
BACKBLAZE_KEY_NAME=tu-key-name
BACKBLAZE_APPLICATION_KEY=tu-application-key
BACKBLAZE_BUCKET_NAME=tu-bucket-name
BACKBLAZE_ENDPOINT=tu-endpoint
BACKBLAZE_REGION=tu-region

# Wompi configuration
WOMPI_PUBLIC_KEY=tu-public-key
WOMPI_PRIVATE_KEY=tu-private-key
WOMPI_INTEGRITY_SECRET=tu-integrity-secret
WOMPI_EVENTS_SECRET=tu-events-secret
WOMPI_REDIRECT_URL=tu-dominio.com/store/order-status
WOMPI_API_BASE_URL=tu-api-base-url

# Configuración adicional de seguridad
# Para producción, cambiar a True
SECURE_SSL_REDIRECT=False
# SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_SECONDS=0
# Para producción, cambiar a True
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
# Para producción, cambiar a True
SECURE_HSTS_PRELOAD=False

# Control de margen online (tienda)
# Para producción, cambiar a True
STORE_MARGIN_GUARD_ENABLED=False
# Para producción, cambiar a 18 o el margen mínimo configurado
STORE_MARGIN_MIN_PERCENT=0
STORE_MARGIN_WOMPI_PERCENT=2.65
STORE_MARGIN_WOMPI_FIXED_FEE=700
STORE_MARGIN_WOMPI_VAT_PERCENT=19
STORE_MARGIN_PACKAGING_COST=2000
STORE_MARGIN_RISK_PERCENT=1.5
STORE_MARGIN_DEFAULT_WEIGHT_PER_ITEM_GRAMS=1100
STORE_MARGIN_DEFAULT_SHIPPING_COST=16000
# Formato: zona:max_peso_gramos:costo
STORE_MARGIN_SHIPPING_COST_MATRIX=local:1500:9000,local:3000:12000,local:5000:15000,regional:1500:13000,regional:3000:17000,regional:5000:22000,national:1500:17000,national:3000:23000,national:5000:29000
