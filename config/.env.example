# ═══════════════════════════════════════════════════════════════
# Golos Inventory — Variables de entorno
# Copia como .env y rellena los valores reales
# ═══════════════════════════════════════════════════════════════

# ─── Entorno ─────────────────────────────────────────────────
# dev:  config.settings_dev
# prod: config.settings_production
DJANGO_SETTINGS_MODULE=config.settings_dev

# ─── Django ──────────────────────────────────────────────────
SECRET_KEY=django-insecure-cambia-esto-en-produccion
# DEBUG=True en desarrollo, False en producción
DEBUG=True

# Hosts permitidos
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0 # En producción, añade tu dominio

# ─── Base de datos ───────────────────────────────────────────
# vacio en desarrollo, rellena en producción
DB_NAME=db_name
DB_USER=db_user
DB_PASSWORD=db_password
DB_HOST=db_host
DB_PORT=db_port

# ─── SSL (False hasta que tengas Nginx + certificado) ────────
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# ─── CORS ────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Email ───────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# vacio en desarrollo, rellena en producción
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=email_host_user
EMAIL_HOST_PASSWORD=email_host_password
DEFAULT_FROM_EMAIL=default_from_email

# ─── JWT ─────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=10080

# ─── Backblaze B2 ────────────────────────────────────────────
BACKBLAZE_KEY_ID=backblaze_key_id
BACKBLAZE_APPLICATION_KEY=backblaze_application_key
BACKBLAZE_BUCKET_NAME=backblaze_bucket_name
BACKBLAZE_ENDPOINT=backblaze_endpoint
BACKBLAZE_REGION=backblaze_region

# ─── Wompi ───────────────────────────────────────────────────
WOMPI_PUBLIC_KEY=wompi_public_key
WOMPI_PRIVATE_KEY=wompi_private_key
WOMPI_INTEGRITY_SECRET=wompi_integrity_secret
WOMPI_EVENTS_SECRET=wompi_events_secret
WOMPI_REDIRECT_URL=wompi_redirect_url # dominio/store/order-status/

# ─── Store automation ────────────────────────────────────────
STORE_AUTO_ADVANCE_ENABLED=False
STORE_AUTO_TO_PROCESSING_MINUTES=5
STORE_AUTO_TO_SHIPPED_MINUTES=120
STORE_AUTO_TO_DELIVERED_MINUTES=1440
STORE_AUTO_TO_COMPLETED_MINUTES=2880

# ─── Shipping ────────────────────────────────────────────────
STORE_SHIPPING_ENABLED=True
STORE_SHIPPING_AUTO_CREATE=False
STORE_SHIPPING_PROVIDER=mock
STORE_SHIPPING_CARRIER_NAME=Golos Logistics
STORE_SHIPPING_MAX_DELIVERY_HOURS=72
STORE_SHIPPING_SERVICES=eco:8000:72,standard:12000:48,express:18000:24
STORE_SHIPPING_WEBHOOK_SECRET=golos_shipping_webhook_secret_2024
STORE_SHIPPING_API_BASE_URL=
STORE_SHIPPING_CREATE_PATH=/shipments
STORE_SHIPPING_API_KEY=
STORE_SHIPPING_AUTH_HEADER=Authorization
STORE_SHIPPING_AUTH_PREFIX=Bearer
STORE_SHIPPING_API_TIMEOUT_SECONDS=15

# ─── Margen de rentabilidad ──────────────────────────────────
STORE_MARGIN_GUARD_ENABLED=True
STORE_MARGIN_MIN_PERCENT=15
STORE_MARGIN_WOMPI_PERCENT=2.65
STORE_MARGIN_WOMPI_FIXED_FEE=0
STORE_MARGIN_WOMPI_VAT_PERCENT=19
STORE_MARGIN_PACKAGING_COST=500
STORE_MARGIN_RISK_PERCENT=2
STORE_MARGIN_DEFAULT_WEIGHT_PER_ITEM_GRAMS=900
STORE_MARGIN_DEFAULT_SHIPPING_COST=12000
STORE_MARGIN_SHIPPING_COST_MATRIX=local:2000:8000,regional:2000:12000,national:2000:15000

# ─── Notificaciones de entrega ───────────────────────────────
STORE_FRONTEND_URL=http://localhost:3000
STORE_DELIVERY_NOTIFICATION_ENABLED=True
STORE_DELIVERY_CONFIRMATION_ENABLED=True
STORE_DELIVERY_TRACKING_PUBLIC_ENABLED=True
STORE_DELIVERY_MIN_TRANSIT_HOURS=2
STORE_DELIVERY_MAX_TRANSIT_HOURS=168

# ─── Operaciones del administrador ───────────────────────────
NOTIFICATIONS_ENABLED=True

TELEGRAM_BOT_TOKEN=token_de_telegram
TELEGRAM_CHAT_ID=id_del_chat_al_que_llegaran_las_notificaciones

# ──────────────────── en produccion no se usa ────────────────
USE_IN_MEMORY_CHANNEL_LAYER=True